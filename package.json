{
  "name": "neoma-managed-app",
  "engines": {
    "node": ">=22.0.0"
  },
  "version": "0.1.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc -p ./libs/managed-app/tsconfig.lib.json",
    "lint": "eslint .",
    "pretest:e2e": "npm run build",
    "test:e2e": "node node_modules/.bin/jest --config ./specs/jest-e2e.json --watch --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.4.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.17",
    "@nestjs/typeorm": "^11.0.0",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.21",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "jest-extended": "^7.0.0",
    "lodash": "^4.17.23",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "sqlite3": "^5.1.7",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.28",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src/",
      "<rootDir>/libs/"
    ],
    "setupFilesAfterEnv": [
      "jest-extended/all",
      "<rootDir>/fixtures/matchers/index.js"
    ],
    "moduleNameMapper": {
      "^fixtures/(.*)$": "<rootDir>/fixtures/$1",
      "^src/(.*)$": "<rootDir>/src/$1"
    }
  }
}
